    <style>
        :root { --primary: #000000; --accent: #D4AF37; --bg: #fdfdfd; --text: #1a1a1a; }
        body { font-family: 'Cairo', sans-serif; background-color: var(--bg); margin: 0; padding: 0; color: var(--text); }
        
        header { background: #fff; padding: 20px 5%; display: flex; justify-content: center; align-items: center; border-bottom: 2px solid #eee; position: sticky; top: 0; z-index: 1000; }
        .brand-logo { font-size: 30px; font-weight: 900; color: var(--primary); text-decoration: none; letter-spacing: 2px; }

        .announcement { background: var(--primary); color: white; text-align: center; padding: 10px; font-size: 13px; font-weight: 600; }

        .container { max-width: 1200px; margin: 30px auto; padding: 0 15px; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 25px; }

        .item { background: #fff; border-radius: 12px; overflow: hidden; border: 1px solid #f0f0f0; transition: all 0.3s ease; display: flex; flex-direction: column; }
        .item:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .item img { width: 100%; height: 280px; object-fit: contain; padding: 15px; box-sizing: border-box; background: #fff; }
        
        .item-info { padding: 20px; flex-grow: 1; text-align: right; }
        .item-category { color: #888; font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; display: block; }
        .item-title { font-size: 16px; font-weight: 700; margin-bottom: 10px; line-height: 1.5; color: #333; height: 48px; overflow: hidden; }
        .item-price { font-size: 22px; font-weight: 900; color: var(--primary); }
        .item-price span { font-size: 14px; margin-right: 4px; font-weight: 400; }
        
        .size-label { display: block; background: #f4f4f4; padding: 8px; border-radius: 6px; font-size: 12px; margin-top: 10px; color: #555; line-height: 1.6; }

        .cta-button { background: #25D366; color: white; text-align: center; padding: 14px; text-decoration: none; font-weight: 700; font-size: 15px; margin: 0 20px 20px; border-radius: 8px; transition: 0.3s; }
        .cta-button:hover { opacity: 0.9; }

        footer { background: #fff; padding: 50px 20px; text-align: center; border-top: 1px solid #eee; margin-top: 60px; }
        .support-info { font-size: 14px; color: #666; margin-top: 20px; line-height: 1.8; }
    </style>
</head>
